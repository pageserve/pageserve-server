# PostgreSQL
POSTGRES_USER=pageserve
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=pageserve

# LLM Backend (OpenAI-compatible)
LLM_BASE_URL=http://host:8000/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3.6-27B

# Separate model for the retrieval step (tree navigation) — empty = use LLM_MODEL
LLM_RETRIEVE_MODEL=

# Auth 
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=change-this-immediately
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRE_HOURS=1
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Profile 
# Leave empty = auto-detect based on server RAM
# Server 4GB:  MAX_FILE_SIZE_MB=20  WORKER_MAX_JOBS=1
# Server 8GB:  MAX_FILE_SIZE_MB=50  WORKER_MAX_JOBS=2  (default)
# Server 16GB: MAX_FILE_SIZE_MB=100 WORKER_MAX_JOBS=3
MAX_FILE_SIZE_MB=
WORKER_MAX_JOBS=

# Redis memory limit
REDIS_MAX_MEMORY=512mb

# Docker memory limits
API_MEMORY_LIMIT=1G
WORKER_MEMORY_LIMIT=2G

# Service 
PORT=8000
RATE_LIMIT_PER_MINUTE=0    # 0 = disabled

# ── SMTP (optional) 
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com
